{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/$USER/.local/bin/ai-agent-status-hook --agent codex"
          }
        ]
      }
    ]
  }
}
