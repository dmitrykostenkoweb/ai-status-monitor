#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/ai-agent-status-env"
ai_status_load_env

widget="${HOME}/.local/bin/ai-agent-status-widget"
pid_file="$AI_STATUS_CACHE_DIR/widget.pid"

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]] && ps -p "$pid" -o args= 2>/dev/null | grep -F "$widget" >/dev/null 2>&1; then
    "${HOME}/.local/bin/ai-agent-status-widget-stop"
    exit 0
  fi
  rm -f "$pid_file"
fi

"${HOME}/.local/bin/ai-agent-status-widget-start"
