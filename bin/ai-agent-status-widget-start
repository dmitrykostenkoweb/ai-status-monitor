#!/usr/bin/env bash
set -euo pipefail

cache_dir="${HOME}/.cache/ai-cli-status-monitor"
widget="${HOME}/.local/bin/ai-agent-status-widget"
pid_file="$cache_dir/widget.pid"
mkdir -p "$cache_dir"

if [[ -f "$pid_file" ]]; then
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]] && ps -p "$pid" -o args= 2>/dev/null | grep -F "$widget" >/dev/null 2>&1; then
    echo "ai-agent-status-widget is already running"
    exit 0
  fi
fi

nohup "$widget" >>"$cache_dir/widget.log" 2>&1 &
echo "$!" >"$pid_file"
echo "ai-agent-status-widget started"
