CONFIG_WARNINGS: list[str] = []
SETTINGS = load_settings(diagnostic=CONFIG_WARNINGS.append)
CACHE_DIR = SETTINGS.cache_dir
CONFIG_DIR = SETTINGS.config_dir
DATA_DIR = SETTINGS.data_dir
STATUS_FILE = CACHE_DIR / "combined.txt"
AGENT_STATUS_FILES = (CACHE_DIR / "claude.json", CACHE_DIR / "codex.json")
