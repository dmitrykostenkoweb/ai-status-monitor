# Per-state palette, taken straight from the design legend.
STATE_COLORS = {
    "thinking": "#A78BFA",
    "reading": "#38BDF8",
    "coding": "#4ADE80",
    "command": "#2DD4BF",
    "analyzing": "#FBBF24",
    "waiting": "#FB7060",
    "error": "#FB7060",
    "done": "#6B7785",
    "idle": "#6B7785",
    "stale": "#566173",
    "neutral": "#9AA4B2",
}
